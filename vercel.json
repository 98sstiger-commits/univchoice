{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    { "src": "api/proxy.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/app.js", "dest": "/app.js" },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate",
        "Pragma": "no-cache",
        "Expires": "0"
      }
    }
  ],
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
